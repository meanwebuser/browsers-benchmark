PROXY_ENABLED=true
PROXY_FILE_PATH=documents/proxies.txt
PROXY_MAX_RETRIES=3
PROXY_FALLBACK_MAX_RETRIES=3
# Note: When PROXY_ENABLED=true, proxies are loaded from PROXY_FILE_PATH
# Each line should contain a full proxy URL like: http://username:password@host:port
# You need at least the same number of proxies as the number of engines you want to test
# PROXY_MAX_RETRIES controls proxy eligibility: only proxies with error_count < PROXY_MAX_RETRIES are used
# PROXY_FALLBACK_MAX_RETRIES controls per-target fallback attempts (0 = unlimited)
# Proxy usage verification is test-only and configured in tests/test_proxy_env.py
# Proxy error_count is reset automatically at benchmark start

PAGE_LOAD_TIMEOUT_S=90
PAGE_STABILIZATION_DELAY_S=5
ENGINES_TO_TEST_MODE=both
BROWSER_TRY_HEADED_WITHOUT_DISPLAY=false
CAMOUFOX_UNLOCK_SHADOW_DOM=true
NUM_WORKERS_MIN=1
NUM_WORKERS_MAX=10
BENCHMARK_REPEAT_COUNT=1
ENGINE_MAX_ATTEMPTS=30
ENGINE_RUN_TIMEOUT_S=5400
MAX_RETRIES=3
